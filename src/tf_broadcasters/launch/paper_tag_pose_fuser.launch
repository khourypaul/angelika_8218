<launch>
    <arg name="node_name" default="paper_tag_pose_fuser"/>
    <arg name="params_file" default="$(find assistive_launch)/config/paper_tag_pose_fuser.yaml"/>

    <node name="$(arg node_name)" pkg="tf_broadcasters" type="paper_tag_pose_fuser.py" output="screen">
        <rosparam command="load" file="$(arg params_file)" subst_value="true"/>
    </node>
</launch>
