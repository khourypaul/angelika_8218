<launch>
    <arg name="node_name" default="paper_tag_detector"/>
    <arg name="params_file" default="$(find assistive_launch)/config/paper_tag_detector.yaml"/>

    <node name="$(arg node_name)" pkg="tf_broadcasters" type="paper_tag_detector.py" output="screen">
        <rosparam command="load" file="$(arg params_file)" subst_value="true"/>
    </node>
</launch>
